GRAMMAR
  DIRECTIVE marker (0 comments) @x
  RULE X
    ALTERNATION
      SEQ
        TERM
          PREDICATE @x = 0;
        TERM *
          GROUP
            ALTERNATION
              SEQ
                TERM
                  STRING "#"
                TERM
                  PREDICATE @x++;
        TERM
          PREDICATE ! @@ = (@x >= 5);
